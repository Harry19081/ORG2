{
  "name": "orgii-collab-hub-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx --yes wrangler@latest dev",
    "deploy": "npx --yes wrangler@latest deploy",
    "typecheck": "tsc --noEmit",
